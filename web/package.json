{
	"name": "@hashgraph/stablecoin-dapp",
	"version": "4.0.2",
	"files": [
		"build/"
	],
	"scripts": {
		"start": "react-app-rewired start",
		"build": "react-app-rewired build",
		"test": "react-app-rewired test --maxWorkers=25% --watchAll=false --cache=false",
		"test:watch": "react-app-rewired test --maxWorkers=50% --watchAll=true",
		"test:update": "react-app-rewired test -u --maxWorkers=50% --watchAll=false",
		"test:ci": "react-app-rewired test --ci --runInBand --watchAll=false --cache=false",
		"clear:cache": "react-app-rewired test --clearCache",
		"clean:modules": "rimraf node_modules",
		"eject": "react-app-rewired eject",
		"lint": "eslint . --ext .ts --ext .mts --fix",
		"prettier": "prettier --config .prettierrc --write .",
		"prettier:check": "prettier --config .prettierrc --check",
		"pre-commit": "npm run lint && npm run prettier",
		"prepack": "npm run build"
	},
	"devDependencies": {
		"@babel/plugin-transform-private-property-in-object": "7.25.9",
		"@types/node": "18.19.80",
		"@types/react-toastify": "4.1.0",
		"@types/redux-mock-store": "1.5.0",
		"@typescript-eslint/eslint-plugin": "6.21.0",
		"@typescript-eslint/parser": "6.21.0",
		"assert": "2.1.0",
		"buffer": "6.0.3",
		"crypto-browserify": "3.12.1",
		"eslint": "8.57.1",
		"eslint-config-prettier": "9.1.0",
		"eslint-config-standard": "17.1.0",
		"eslint-plugin-import": "2.31.0",
		"eslint-plugin-n": "15.7.0",
		"eslint-plugin-promise": "6.6.0",
		"eslint-plugin-react": "7.37.4",
		"https-browserify": "1.0.0",
		"i18next": "22.5.1",
		"i18next-browser-languagedetector": "7.2.2",
		"os-browserify": "0.3.0",
		"phosphor-react": "1.4.1",
		"prettier": "2.8.8",
		"process": "0.11.10",
		"react-app-rewired": "2.2.1",
		"react-dev-utils": "12.0.1",
		"react-i18next": "12.3.1",
		"stream-browserify": "3.0.0",
		"stream-http": "3.2.0",
		"ts-jest": "29.2.6",
		"typescript": "4.9.4",
		"url": "0.11.4"
	},
	"dependencies": {
		"@chakra-ui/icons": "2.2.4",
		"@chakra-ui/react": "2.6.1",
		"@emotion/react": "11.14.0",
		"@emotion/styled": "11.14.0",
		"@hashgraph/proto": "2.25.0",
		"@hashgraph/stablecoin-npm-sdk": "*",
		"@reduxjs/toolkit": "1.9.7",
		"@testing-library/jest-dom": "5.17.0",
		"@testing-library/react": "14.0.0-alpha.3",
		"@testing-library/user-event": "14.6.1",
		"@types/jest": "29.5.14",
		"@types/react": "18.3.18",
		"@types/react-datepicker": "4.19.6",
		"@types/react-dom": "18.3.5",
		"@types/react-redux": "7.1.34",
		"axios": "1.8.2",
		"babel-preset-react-app": "10.1.0",
		"browserify-zlib": "0.2.0",
		"chakra-react-select": "4.10.1",
		"framer-motion": "8.5.5",
		"html-webpack-plugin": "5.6.3",
		"maskdata": "1.3.3",
		"moment": "2.30.1",
		"named-urls": "2.0.1",
		"path-browserify": "1.0.1",
		"react": "18.3.1",
		"react-app-polyfill": "3.0.0",
		"react-datepicker": "4.25.0",
		"react-device-detect": "2.2.3",
		"react-dom": "18.3.1",
		"react-hook-form": "7.54.2",
		"react-number-format": "5.4.3",
		"react-redux": "8.1.3",
		"react-router-dom": "6.30.0",
		"react-scripts": "5.0.1",
		"react-switch": "7.1.0",
		"react-toastify": "9.1.3",
		"redux-mock-store": "1.5.5",
		"terminal-link": "2.1.1",
		"web-vitals": "3.5.2",
		"webpack": "5.98.0"
	},
	"eslintConfig": {
		"extends": [
			"react-app",
			"react-app/jest"
		]
	},
	"typesVersions": {
		"*": {
			"*": [
				"./lib/*"
			]
		}
	},
	"types": "./lib/*.d.ts",
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"overrides": {
		"react-refresh": "0.11.0"
	},
	"jest": {
		"preset": "ts-jest",
		"testEnvironment": "jsdom",
		"clearMocks": true,
		"testTimeout": 60000,
		"modulePaths": [
			"<rootDir>/src"
		],
		"setupFilesAfterEnv": [
			"<rootDir>/src/test/setupTests.tsx"
		],
		"moduleNameMapper": {
			"^(\\.{1,2}/.*)\\.(m)?js$": "$1",
			"axios": "<rootDir>/../node_modules/axios/dist/node/axios.cjs",
			"blade": "<rootDir>/src/mocks/blade-sdk-mock.js",
			"hedera-wallet-connect": "<rootDir>/src/mocks/hedera-wallet-connect-sdk-mock.js",
			"fireblocks-sdk": "<rootDir>/src/mocks/fireblocks-sdk-mock.js"
		},
		"transform": {
			"^.+\\.ts?$": "ts-jest",
			"^.+\\.[t|j]sx?$": "babel-jest"
		},
		"transformIgnorePatterns": [
			"node_modules/(?!@ngrx|(?!deck.gl)|ng-dynamic)"
		]
	}
}