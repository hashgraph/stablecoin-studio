{
  "name": "@hashgraph/hedera-stable-coin",
  "version": "4.1.0",
  "private": true,
  "description": "Stablecoin studio",
  "keywords": [
    "stablecoin",
    "hedera",
    "blockchain"
  ],
  "license": "Apache-2.0",
  "repository": "https://github.com/hashgraph/stablecoin-studio",
  "scripts": {
    "setup": "npm run install:all",
    "install:all": "npm install && npm run build --workspaces",
    "install:backend": "npm install --workspace=apps/backend",
    "install:contracts": "npm install --workspace=packages/contracts",
    "install:sdk": "npm install --workspace=packages/sdk",
    "install:cli": "npm install --workspace=apps/cli",
    "install:web": "npm install --workspace=apps/web",
    "compile:contracts": "npm run compile --workspace=packages/contracts",
    "coverage:contracts": "npm run coverage --workspace=packages/contracts",
    "test:contracts": "npm run test --workspace=packages/contracts",
    "build:sdk": "npm run build --workspace=packages/sdk",
    "build:cli": "npm run build --workspace=apps/cli",
    "build:cli:full": "npm run build:backend && npm run build:contracts && npm run build:sdk && npm run build:cli",
    "build:backend": "npm run build --workspace=apps/backend",
    "build:contracts": "npm run compile:force --workspace=packages/contracts",
    "build:web": "npm run build --workspace=apps/web",
    "pack:backend": "npm pack --workspace=apps/backend",
    "pack:contracts": "npm pack --workspace=packages/contracts",
    "pack:sdk": "npm pack --workspace=packages/sdk",
    "pack:cli": "npm pack --workspace=apps/cli",
    "pack:web": "npm pack --workspace=apps/web",
    "clean": "concurrently \"npm run --silent clean:all:build\" \"npm run --silent clean:all:modules\" > '/dev/null' 2>&1",
    "clean:all:modules": "concurrently \"npx --yes rimraf node_modules\" \"npm run clean:sdk:modules\" \"npm run clean:backend:modules\" \"npm run clean:cli:modules\" \"npm run clean:web:modules\" \"npm run clean:contracts:modules\"",
    "clean:sdk:modules": "npm run clean:modules --workspace=packages/sdk",
    "clean:backend:modules": "npm run clean:modules --workspace=apps/backend",
    "clean:cli:modules": "npm run clean:modules --workspace=apps/cli",
    "clean:web:modules": "npm run clean:modules --workspace=apps/web",
    "clean:contracts:modules": "npm run clean:modules --workspace=packages/contracts",
    "clean:all:build": "concurrently \"npm run clean:sdk:build\" \"npm run clean:backend:build\" \"npm run clean:cli:build\"",
    "clean:sdk:build": "rimraf ./sdk/build",
    "clean:backend:build": "rimraf ./backend/dist",
    "clean:cli:build": "rimraf ./cli/build",
    "clean:web:build": "rimraf ./web/build",
    "clean:contracts:build": "rimraf ./contracts/build",
    "clean:contracts:all": "rimraf ./contracts/node_modules ./contracts/artifacts ./contracts/typechain-types ./contracts/cache",
    "install:docs": "npm install --workspace=apps/docs",
    "build:docs": "npm run build --workspace=apps/docs",
    "docs": "npm run start --workspace=apps/docs",
    "prettier": "concurrently \"npm run prettier:sdk\" \"npm run prettier:backend\" \"npm run prettier:web\" \"npm run prettier:cli\" \"npm run prettier:contracts\"",
    "prettier:sdk": "npm run prettier --workspace=packages/sdk",
    "prettier:backend": "npm run prettier --workspace=apps/backend",
    "prettier:web": "npm run prettier --workspace=apps/web",
    "prettier:cli": "npm run prettier --workspace=apps/cli",
    "prettier:contracts": "npm run prettier --workspace=packages/contracts",
    "prettier:check": "concurrently \"npm run prettier:sdk:check\" \"npm run prettier:backend:check\" \"npm run prettier:web:check\" \"npm run prettier:cli:check\" \"npm run prettier:contracts:check\"",
    "prettier:contracts:check": "npm run prettier:check --workspace=packages/contracts",
    "prettier:sdk:check": "npm run prettier:check --workspace=packages/sdk",
    "prettier:backend:check": "npm run prettier:check --workspace=apps/backend",
    "prettier:web:check": "npm run prettier:check --workspace=apps/web",
    "prettier:cli:check": "npm run prettier:check --workspace=apps/cli",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.0",
    "@commitlint/config-conventional": "19.8.0",
    "concurrently": "7.6.0",
    "dotenv": "16.4.7",
    "rimraf": "4.4.1"
  },
  "dependencies": {
    "husky": "9.1.7"
  },
  "overrides": {
    "react-refresh": "0.11.0",
    "webpack": "5.104.1",
    "bfj": "9.1.3",
    "underscore": "1.13.8",
    "@nestjs/cli": {
      "glob": "10.5.0"
    },
    "serialize-javascript": "7.0.4",
    "squirrelly": "9.1.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}